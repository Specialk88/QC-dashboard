        <div class="legend-item"><span class="legend-line" style="background:#E24B4A"></span>Cum %</div>
        <div class="legend-item"><span class="legend-dash"></span>80% line</div>
      </div>
    </div>

  </div>
</div>

<script>
function makePareto(id, labels, qty, cum) {
  const n = labels.length;
  const ctx = document.getElementById(id);
  new Chart(ctx, {
    data: {
      labels: labels,
      datasets: [
        {
          type: 'bar',
          label: 'Defect Qty',
          data: qty,
          backgroundColor: '#BFDBFE',
          borderColor: '#3B82F6',
          borderWidth: 1,
          yAxisID: 'y',
          order: 2
        },
        {
          type: 'line',
          label: 'Cum %',
          data: cum,
          borderColor: '#E24B4A',
          backgroundColor: 'transparent',
          borderWidth: 2,
          pointRadius: 3,
          pointBackgroundColor: '#E24B4A',
          yAxisID: 'y1',
          order: 1
        },
        {
          type: 'line',
          label: '80% line',
          data: Array(n).fill(80),
          borderColor: '#9CA3AF',
          backgroundColor: 'transparent',
          borderWidth: 1.5,
          borderDash: [5, 4],
          pointRadius: 0,
          yAxisID: 'y1',
          order: 1
        }
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: { mode: 'index', intersect: false }
      },
      scales: {
        x: {
          ticks: {
            font: { size: 10, family: 'ui-sans-serif, system-ui, -apple-system, sans-serif' },
            maxRotation: 35,
            autoSkip: false,
            color: '#6B7280'
          },
          grid: { display: false }
        },
        y: {
          position: 'left',
          beginAtZero: true,
          ticks: {
            font: { size: 10 },
            color: '#6B7280'
          },
          grid: { color: 'rgba(0,0,0,.06)' }
        },
        y1: {
          position: 'right',
          min: 0,
          max: 100,
          ticks: {
            font: { size: 10 },
            color: '#6B7280',
            callback: v => v + '%'
          },
          grid: { display: false }
        }
      }
    }
  });
}

makePareto(
  'c_qcpth1',
  ['Misinserted', 'Insuff solder', 'Missing', 'No lead protrusion', 'Excess solder', 'Damaged', 'Wrong Part', 'Others'],
  [572, 206, 164, 43, 34, 18, 13, 7],
  [54.12, 73.60, 89.12, 93.19, 96.40, 98.11, 99.34, 100.0]
);

makePareto(
  'c_fvt',
  ['Contact problem', 'Tester defect', 'Missing', 'Damaged', 'Electrically Def.', 'Operator Error', 'Others'],
  [141, 80, 10, 8, 8, 4, 54],
  [53.21, 83.40, 87.17, 90.19, 93.21, 94.72, 100.0]
);

makePareto(
  'c_ict',
  ['Tester defect', 'Insuff solder', 'Contact problem', 'Lifted lead', 'No analysis'],
  [76, 9, 8, 4, 2],
  [76.77, 85.86, 93.94, 97.98, 100.0]
);
</script>
</body>
</html>
