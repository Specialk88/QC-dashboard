      <div class="risk-badge">FPY 93.88% — Lowest in line</div>
    </div>
  </div>

  <!-- PCBA + UNIT Summary -->
  <div class="section-label">Process Summary</div>
  <div class="table-grid">
    <div>
      <div style="font-size:13px;font-weight:600;color:var(--text-secondary);margin-bottom:6px">MI PCBA</div>
      <div class="table-card">
        <table>
          <thead>
            <tr><th>Process</th><th>Input</th><th>Fail</th><th>Defect%</th><th>FPY</th></tr>
          </thead>
          <tbody>
            <tr><td>AOI1</td><td>16,480</td><td>49</td><td>0.30%</td><td>99.70%</td></tr>
            <tr><td>QCSMT1</td><td>16,476</td><td>2</td><td>0.01%</td><td>99.99%</td></tr>
            <tr><td>AOI2</td><td>16,568</td><td>107</td><td>0.65%</td><td>99.35%</td></tr>
            <tr><td>QCSMT2</td><td>16,517</td><td>0</td><td>0.00%</td><td>100.00%</td></tr>
            <tr><td>ICT</td><td>17,855</td><td>200</td><td>1.12%</td><td>98.88%</td></tr>
            <tr class="risk-row"><td>QCPTH1</td><td>17,265</td><td>1,057</td><td>6.12%</td><td>93.88%</td></tr>
            <tr><td>Hipot</td><td>16,574</td><td>105</td><td>0.63%</td><td>99.37%</td></tr>
            <tr><td>FVT</td><td>16,559</td><td>305</td><td>1.84%</td><td>98.16%</td></tr>
            <tr><td>Vision</td><td>1,256</td><td>27</td><td>2.15%</td><td>97.85%</td></tr>
          </tbody>
        </table>
      </div>
    </div>
    <div>
      <div style="font-size:13px;font-weight:600;color:var(--text-secondary);margin-bottom:6px">MI UNIT</div>
      <div class="table-card">
        <table>
          <thead>
            <tr><th>Process</th><th>Input</th><th>Fail</th><th>Defect%</th><th>FPY</th></tr>
          </thead>
          <tbody>
            <tr><td>FVTAUTO-ASSEMBLY2</td><td>17,513</td><td>79</td><td>0.45%</td><td>99.55%</td></tr>
            <tr><td>Aging</td><td>17,538</td><td>176</td><td>1.00%</td><td>99.00%</td></tr>
            <tr><td>QAPSA</td><td>17,472</td><td>37</td><td>0.21%</td><td>99.79%</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Top 5 Tables -->
  <div class="section-label">Top 5 Analysis</div>
  <div class="table-grid">
    <div>
      <div style="font-size:13px;font-weight:600;color:var(--text-secondary);margin-bottom:6px">By Defect Rate</div>
      <div class="table-card">
        <table>
          <thead>
            <tr><th>Process</th><th>Input</th><th>Fail</th><th>Defect%</th><th>FPY</th></tr>
          </thead>
          <tbody>
            <tr class="risk-row"><td>QCPTH1</td><td>17,265</td><td>1,057</td><td>6.12%</td><td>93.88%</td></tr>
            <tr><td>Vision</td><td>1,256</td><td>27</td><td>2.15%</td><td>97.85%</td></tr>
            <tr><td>FVT</td><td>16,559</td><td>305</td><td>1.84%</td><td>98.16%</td></tr>
            <tr><td>ICT</td><td>17,855</td><td>200</td><td>1.12%</td><td>98.88%</td></tr>
            <tr><td>Aging</td><td>17,538</td><td>176</td><td>1.00%</td><td>99.00%</td></tr>
          </tbody>
        </table>
      </div>
    </div>
    <div>
      <div style="font-size:13px;font-weight:600;color:var(--text-secondary);margin-bottom:6px">By Fail Qty + Risk Level</div>
      <div class="table-card">
        <table>
          <thead>
            <tr><th>Process</th><th>Input</th><th>Fail</th><th>Defect%</th><th>Risk</th></tr>
          </thead>
          <tbody>
            <tr class="risk-row"><td>QCPTH1</td><td>17,265</td><td>1,057</td><td>6.12%</td><td><span class="badge badge-risk">RISK</span></td></tr>
            <tr><td>FVT</td><td>16,559</td><td>305</td><td>1.84%</td><td><span class="badge badge-watch">WATCH</span></td></tr>
            <tr><td>ICT</td><td>17,855</td><td>200</td><td>1.12%</td><td><span class="badge badge-watch">WATCH</span></td></tr>
            <tr><td>Aging</td><td>17,538</td><td>176</td><td>1.00%</td><td><span class="badge badge-ok">OK</span></td></tr>
            <tr><td>AOI2</td><td>16,568</td><td>107</td><td>0.65%</td><td><span class="badge badge-ok">OK</span></td></tr>
          </tbody>
        </table>
      </div>
