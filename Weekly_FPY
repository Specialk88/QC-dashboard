      <div class="fpy-progress-track">
        <div class="fpy-progress-fill" style="width:89.5%"></div>
      </div>
      <div class="fpy-gap-row">
        <span class="fpy-gap-label">▼ -10.11%p vs target</span>
        <span class="fpy-target-label">Target 96.40%</span>
      </div>
    </div>
    <div class="kpi-card">
      <div class="kpi-label">PCBA FPY</div>
      <div class="kpi-value">87.75%</div>
      <div class="kpi-sub">Accumulated yield</div>
    </div>
    <div class="kpi-card">
      <div class="kpi-label">UNIT FPY</div>
      <div class="kpi-value">98.34%</div>
