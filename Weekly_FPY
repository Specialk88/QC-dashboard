    </div>

    <div class="pareto-card">
      <div class="pareto-title">FVT</div>
      <div class="pareto-sub">Top defect analysis · Total fails: 305</div>
      <div class="chart-wrap" style="height:280px">
        <canvas id="c_fvt" role="img" aria-label="Pareto chart FVT. Top: Contact problem 141 (53.21%).">FVT defects: Contact problem 141, Tester defect 80, Missing 10, Damaged 8, Electrically Defective 8, Operator Error 4, Others 54.</canvas>
      </div>
      <div class="legend">
        <div class="legend-item"><span class="legend-swatch" style="background:#60A5FA"></span>Defect Qty</div>
        <div class="legend-item"><span class="legend-line" style="background:#E24B4A"></span>Cum %</div>
        <div class="legend-item"><span class="legend-dash"></span>80% line</div>
      </div>
    </div>

    <div class="pareto-card">
      <div class="pareto-title">ICT</div>
      <div class="pareto-sub">Top defect analysis · Total fails: 99</div>
      <div class="chart-wrap" style="height:280px">
        <canvas id="c_ict" role="img" aria-label="Pareto chart ICT. Top: Tester defect 76 (76.77%).">ICT defects: Tester defect 76, Insuff solder 9, Contact problem 8, Lifted lead 4, No analysis 2.</canvas>
      </div>
