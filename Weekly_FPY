<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>Microinverter Quality Dashboard</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg-page: #f5f6f8;
    --bg-card: #ffffff;
    --bg-secondary: #f8f9fb;
    --border: #e8eaed;
    --border-strong: #d1d5db;
    --text-primary: #111827;
    --text-secondary: #6b7280;
    --text-tertiary: #9ca3af;
    --blue-50: #EFF6FF;
    --blue-100: #DBEAFE;
    --blue-400: #60A5FA;
    --blue-600: #2563EB;
    --blue-800: #1E40AF;
    --red-50: #FFF5F5;
    --red-100: #FEE2E2;
    --red-400: #F87171;
    --red-600: #DC2626;
    --red-800: #991B1B;
    --amber-50: #FFFBEB;
    --amber-100: #FEF3C7;
    --amber-600: #D97706;
    --amber-800: #92400E;
    --green-50: #F0FDF4;
    --green-100: #DCFCE7;
    --green-600: #16A34A;
    --green-800: #166534;
    --radius-sm: 8px;
    --radius-md: 12px;
    --radius-lg: 16px;
  }

  body {
    font-family: 'Söhne', ui-sans-serif, system-ui, -apple-system, 'Helvetica Neue', Arial, sans-serif;
    background: var(--bg-page);
    color: var(--text-primary);
    min-height: 100vh;
    padding: 20px 16px 40px;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  .container { max-width: 1400px; margin: 0 auto; }

  /* Header */
  .header { margin-bottom: 24px; }
  .header h1 {
    font-size: clamp(20px, 4vw, 28px);
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.3px;
  }
  .header p {
    font-size: 13px;
    color: var(--text-tertiary);
    margin-top: 4px;
  }

  /* Section label */
  .section-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: .7px;
    text-transform: uppercase;
    color: var(--text-tertiary);
    margin: 24px 0 10px;
  }

  /* KPI Grid */
  .kpi-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 12px;
    margin-bottom: 8px;
  }

  /* FPY gap-to-target */
  .fpy-progress-track {
    height: 6px;
    background: var(--red-100);
    border-radius: 99px;
    margin-top: 10px;
    overflow: hidden;
    position: relative;
  }
  .fpy-progress-fill {
    height: 100%;
    background: #E24B4A;
    border-radius: 99px;
  }
  .fpy-gap-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 5px;
  }
  .fpy-gap-label { font-size: 11px; color: var(--red-800); font-weight: 600; }
  .fpy-target-label { font-size: 11px; color: var(--text-tertiary); }

  .kpi-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 16px 18px;
    transition: box-shadow .15s;
  }
  .kpi-card:hover { box-shadow: 0 2px 10px rgba(0,0,0,.07); }
  .kpi-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: .5px;
    text-transform: uppercase;
    color: var(--text-tertiary);
  }
  .kpi-value {
    font-size: 32px;
    font-weight: 600;
    color: var(--text-primary);
    line-height: 1.15;
    margin-top: 4px;
    letter-spacing: -1px;
    font-variant-numeric: tabular-nums;
  }
  .kpi-sub {
    font-size: 12px;
    color: var(--text-tertiary);
    margin-top: 3px;
  }

  /* Risk KPI card */
  .kpi-card.risk {
    border-color: #FCA5A5;
    background: var(--red-50);
  }
  .kpi-card.risk .kpi-label { color: var(--red-800); }
  .kpi-card.risk .kpi-value { color: var(--red-800); }
  .kpi-card.risk .kpi-sub { color: var(--red-600); }
  .risk-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    background: var(--red-100);
    color: var(--red-800);
    font-size: 11px;
    font-weight: 600;
    padding: 3px 9px;
    border-radius: 20px;
    margin-top: 6px;
    letter-spacing: .2px;
  }
  .risk-badge::before { content: "⚠"; }

  /* Tables */
  .table-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    overflow: hidden;
    margin-bottom: 8px;
  }

  table { width: 100%; border-collapse: collapse; }
  thead th {
    background: var(--bg-secondary);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: .5px;
    text-transform: uppercase;
    color: var(--text-tertiary);
    padding: 10px 14px;
    border-bottom: 1px solid var(--border);
    text-align: left;
    white-space: nowrap;
  }
  thead th:not(:first-child) { text-align: right; }
  tbody td {
    padding: 9px 14px;
    border-bottom: 1px solid var(--border);
    font-size: 13px;
    color: var(--text-primary);
    font-variant-numeric: tabular-nums;
  }
  tbody td:not(:first-child) { text-align: right; }
  tbody tr:last-child td { border-bottom: none; }
  tbody tr:hover td { background: var(--bg-secondary); }

  /* Risk row */
  tbody tr.risk-row td {
    background: var(--red-50);
    color: var(--red-800);
    font-weight: 500;
  }
  tbody tr.risk-row:hover td { background: var(--red-100); }
  tbody tr.risk-row td:first-child::after {
    content: "  ⚠";
    font-size: 11px;
    opacity: .8;
  }

  /* Badges */
  .badge {
    display: inline-block;
    padding: 2px 9px;
    border-radius: 20px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: .3px;
  }
  .badge-risk { background: var(--red-100); color: var(--red-800); }
  .badge-watch { background: var(--amber-100); color: var(--amber-800); }
  .badge-ok { background: var(--green-100); color: var(--green-800); }

  /* Two-col grid for tables */
  .table-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 16px;
    margin-bottom: 8px;
  }

  /* Pareto */
  .pareto-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: 16px;
  }

  .pareto-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 18px 20px;
  }
  .pareto-card.risk-card { border-color: #FCA5A5; }

  .pareto-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 2px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .pareto-sub {
    font-size: 12px;
    color: var(--text-tertiary);
    margin-bottom: 14px;
  }
  .chart-wrap { position: relative; width: 100%; }
  .legend {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 12px;
    font-size: 11px;
    color: var(--text-secondary);
  }
  .legend-item { display: flex; align-items: center; gap: 5px; }
  .legend-swatch {
    width: 10px; height: 10px;
    border-radius: 2px;
    flex-shrink: 0;
  }
  .legend-line {
    width: 18px; height: 2px;
    flex-shrink: 0;
  }
  .legend-dash {
    width: 18px; height: 0;
    border-top: 2px dashed #888;
    flex-shrink: 0;
  }

  /* Responsive */
  @media (max-width: 600px) {
    .kpi-grid { grid-template-columns: repeat(2, 1fr); }
    .kpi-value { font-size: 26px; }
    .pareto-grid, .table-grid { grid-template-columns: 1fr; }
    body { padding: 14px 12px 32px; }
    thead th, tbody td { padding: 8px 10px; font-size: 12px; }
  }
</style>
</head>
<body>
<div class="container">

  <!-- Header -->
  <div class="header">
    <h1>Microinverter Quality Dashboard</h1>
    <p>Weekly production report</p>
  </div>

  <!-- KPI Cards -->
  <div class="section-label">Key Metrics</div>
  <div class="kpi-grid">
    <div class="kpi-card risk">
